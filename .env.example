# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_ALLOWED_USER_ID=123456789012345678
ALLOWED_ROLE_IDS=
FREE_CHAT_CHANNELS=

# Ollama endpoint
OLLAMA_URL=http://localhost:11434/api/chat

# Qwen3.5 role-based models
OLLAMA_ROUTER_MODEL=qwen3.5:0.8b
OLLAMA_MAIN_MODEL=qwen3.5:4b
OLLAMA_HEAVY_MODEL=qwen3.5:9b

# RTX 3070-safe context sizes
OLLAMA_ROUTER_CTX=2048
OLLAMA_MAIN_CTX=4096
OLLAMA_HEAVY_CTX=4096

# Output token limits
OLLAMA_ROUTER_PREDICT=128
OLLAMA_MAIN_PREDICT=512
OLLAMA_HEAVY_PREDICT=768

# Keep-alive
OLLAMA_ROUTER_KEEP_ALIVE=5m
OLLAMA_MAIN_KEEP_ALIVE=10m
OLLAMA_HEAVY_KEEP_ALIVE=0

# Adaptive routing
ENABLE_ADAPTIVE_ROUTING=1
ROUTER_CONFIDENCE_EARLY_EXIT=0.85
ROUTER_CONFIDENCE_VERIFY=0.65
ROUTER_CONFIDENCE_HEAVY=0.45

# Agent loop
REACT_MAX_TURNS=2

# Optional quality mode
ENABLE_BEST_OF_N=0
BEST_OF_N_MAX=3

# Dangerous tools disabled by default
ENABLE_LOCAL_PYTHON_TOOL=0
ENABLE_CODEX_TOOLS=0
ENABLE_CODEX_BRIDGE_AUTOSTART=0

# Fetch limits
FETCH_MAX_CHARS=6000
FETCH_MAX_TEXT_BYTES=524288
FETCH_MAX_JSON_BYTES=524288
FETCH_MAX_HTML_BYTES=1048576

# Codex
CODEX_CMD=codex
CODEX_LOG_TAIL_LINES=80
